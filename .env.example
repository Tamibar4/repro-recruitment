# Gmail SMTP - for password reset and registration notification emails
# How to set up:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create an app password for "Mail" (requires 2-Step Verification enabled)
# 3. Copy the 16-character password and paste it below

GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# URL of the app (used in email links)
APP_URL=http://localhost:3000
